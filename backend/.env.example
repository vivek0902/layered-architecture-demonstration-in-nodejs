# ==========================================
# SERVER CONFIGURATION
# ==========================================
# Port number on which the server will run
PORT=3000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB connection URI
# Example: mongodb+srv://username:password@cluster.mongodb.net/database?appName=AppName
MONGODB_URI=add your mongodb uri here

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# ==========================================
# APPLICATION ENVIRONMENT
# ==========================================
# Environment: development, production, test
NODE_ENV=production

# ==========================================
# DNS CONFIGURATION
# ==========================================
# Comma-separated list of DNS servers
DNS_SERVERS=1.1.1.1,8.8.8.8

# ==========================================
# API CONFIGURATION
# ==========================================
# API base path prefix
API_PREFIX=/api/v1

# API version
API_VERSION=v1

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Allowed origin(s) for CORS requests
# Use specific domain in production: https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# Allow credentials in CORS requests (cookies, authorization headers)
CORS_CREDENTIALS=true

# Allowed HTTP methods for CORS requests
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# ==========================================
# FRONTEND CONFIGURATION
FRONTEND_URL=https://your-domain.com

